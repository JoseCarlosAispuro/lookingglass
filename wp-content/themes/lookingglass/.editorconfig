# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# TypeScript and JavaScript files
[*.{ts,tsx,js,jsx}]
indent_size = 4

# JSON files
[*.json]
indent_size = 4

# CSS, SCSS, and related files
[*.{css,scss,sass,less}]
indent_size = 4

# PHP files
[*.php]
indent_size = 4

# HTML and template files
[*.{html,blade.php}]
indent_size = 4

# Configuration files
[*.{yml,yaml}]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false