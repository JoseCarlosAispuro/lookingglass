{
    "name": "acf/quotes-slider",
    "apiVersion": 3,
    "title": "Quotes Slider",
    "description": "",
    "category": "layout",
    "icon": "editor-quote",
    "keywords": ["slider", "quote", "quotes"],
    "acf": {
        "mode": "edit",
        "renderTemplate": "../block.php"
    },
    "supports": {
        "anchor": true,
        "className": true,
        "align": ["full"],
        "color": {
            "text": false
        }
    },
    "attributes": {
        "backgroundColor": {
            "type": "string",
            "default": "white"
        },
        "textColor": {
            "type": "string",
            "default": "black"
        }
    },
    "example": {
        "attributes": {
            "mode": "preview",
            "data": {
                "preview_image": "/dist/images/previews/quotes-slider.jpg"
            }
        }
    }
}
