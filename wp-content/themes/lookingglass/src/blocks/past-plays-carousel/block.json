{
    "name": "acf/past-plays-carousel",
    "apiVersion": 3,
    "title": "Past Plays Carousel Block",
    "description": "Full carousel section with customizable headline, support text, plays and call-to-action button.",
    "category": "layout",
    "icon": "backup",
    "keywords": ["past", "carousel", "plays"],
    "acf": {
        "mode": "edit",
        "renderTemplate": "../block.php"
    },
    "supports": {
        "customClassName": true,
        "anchor": true,
        "className": true,
        "align": ["full"],
        "color": {
            "background": true,
            "text": false
        }
    },
    "attributes": {
        "backgroundColor": {
            "type": "string",
            "default": "white"
        }
    },
    "example": {
        "attributes": {
            "mode": "preview",
            "data": {
                "preview_image": "/dist/images/previews/past-plays-carousel.png"
            }
        }
    }
}
