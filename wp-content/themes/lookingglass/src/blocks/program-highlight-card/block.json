{
    "name": "acf/program-highlight-card",
    "apiVersion": 3,
    "title": "Program Highlight Card",
    "description": "A promotional banner block designed to highlight a specific program.",
    "category": "layout",
    "icon": "align-center",
    "keywords": ["promo", "program", "banner", "highlight", "card"],
    "acf": {
        "mode": "edit",
        "renderTemplate": "../block.php"
    },
    "supports": {
        "anchor": true,
        "className": true,
        "align": ["full"],
        "color": {
            "text": false
        }
    },
    "attributes": {
        "backgroundColor": {
            "type": "string",
            "default": "white"
        }
    },
    "example": {
        "attributes": {
            "mode": "preview",
            "data": {
                "preview_image": "/dist/images/previews/program-highlight-card.jpg"
            }
        }
    }
}
