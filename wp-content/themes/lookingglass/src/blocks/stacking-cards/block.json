{
    "name": "acf/stacking-cards",
    "title": "Stacking Cards Block",
    "description": "A stacking cards block to demonstrate the new flat file structure",
    "category": "common",
    "icon": "align-wide",
    "keywords": ["stacking", "cards"],
    "acf": {
        "mode": "edit",
        "renderTemplate": "../block.php"
    },
    "supports": {
        "anchor": true,
        "className": true,
        "color": {
            "text": true
        }
    },
    "attributes": {
        "backgroundColor": {
            "type": "string",
            "default": "black"
        },
        "textColor": {
            "type": "string",
            "default": "white"
        }
    },
    "example": {
        "attributes": {
            "mode": "preview",
            "data": {
                "preview_image": "/dist/images/previews/stacking-cards.png"
            }
        }
    }
}
