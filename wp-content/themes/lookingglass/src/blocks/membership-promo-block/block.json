{
    "name": "acf/membership-promo-block",
    "title": "Membership Promo Block",
    "description": "Promotional component for membership/insider conversion with editorial content, feature image, and quote slider.",
    "category": "formatting",
    "icon": "groups",
    "keywords": ["membership", "promo", "insider", "quotes", "slider"],
    "acf": {
        "mode": "edit",
        "renderTemplate": "../block.php"
    },
    "supports": {
        "align": false,
        "anchor": true,
        "customClassName": true,
        "jsx": false,
        "color": {
            "text": false
        }
    },
    "attributes": {
        "backgroundColor": {
            "type": "string",
            "default": "white"
        }
    },
    "example": {
        "attributes": {
            "mode": "preview",
            "data": {
                "preview_image": "/dist/images/previews/membership-promo.jpg"
            }
        }
    }
}
